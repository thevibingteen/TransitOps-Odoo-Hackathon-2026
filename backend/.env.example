# Port used by the local API server
PORT=5050

# Production PostgreSQL / Supabase configuration (wire these into a repository adapter before deployment)
DATABASE_URL=postgresql://user:password@host:5432/transitops
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-key

# Kaggle CSV source folders used by the import script
LOGISTICS_DATA_ROOT=C:/path/to/Logistics data odoo
MAINTENANCE_DATA_ROOT=C:/path/to/Logistics vehicle mainatance data
